{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Insight umbrella values",
  "description": "Minimal schema. Validates the unified per-dependency shape (deploy + flat host/port/passwordSecret) and enforces image.tag is set on every app service.",
  "type": "object",
  "properties": {
    "credentials": {
      "type": "object",
      "properties": {
        "deploymentMode": { "enum": ["helm", "gitops"] },
        "autoGenerate":   { "type": "boolean" }
      }
    },

    "ingestion": {
      "type": "object",
      "properties": {
        "templates": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "toolboxImage":    { "type": "string" },
        "jiraEnrichImage": { "type": "string" },
        "reconcile": {
          "type": "object",
          "properties": {
            "schedule": { "type": "string", "default": "*/15 * * * *" },
            "destinationId": { "type": "string" },
            "destinationName": { "type": "string" },
            "argoInstanceId": { "type": "string" },
            "tenantId": { "type": "string" },
            "logs": {
              "type": "object",
              "properties": {
                "size":         { "type": "string", "default": "5Gi" },
                "storageClass": { "type": "string" }
              }
            },
            "resources": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "object",
                  "properties": {
                    "cpu":    { "type": "string", "default": "100m" },
                    "memory": { "type": "string", "default": "128Mi" }
                  }
                },
                "limits": {
                  "type": "object",
                  "properties": {
                    "cpu":    { "type": "string", "default": "500m" },
                    "memory": { "type": "string", "default": "512Mi" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "airbyte": {
      "type": "object",
      "properties": {
        "releaseName": { "type": "string", "default": "airbyte" },
        "apiUrl": { "type": "string" },
        "jwtSecret": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "key":  { "type": "string" }
          },
          "required": ["name", "key"]
        },
        "authSecret": {
          "type": "object",
          "properties": {
            "name":            { "type": "string" },
            "clientIdKey":     { "type": "string" },
            "clientSecretKey": { "type": "string" }
          },
          "required": ["name"]
        }
      }
    },

    "global": {
      "type": "object",
      "properties": {
        "imageRegistry":    { "type": "string" },
        "imagePullPolicy":  { "enum": ["Always", "IfNotPresent", "Never"] },
        "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
        "storageClass":     { "type": "string" }
      }
    },

    "clickhouse": { "$ref": "#/definitions/infraDep" },
    "mariadb":    { "$ref": "#/definitions/infraDep" },
    "redis":      { "$ref": "#/definitions/infraDep" },
    "redpanda":   { "$ref": "#/definitions/infraDep" },

    "apiGateway": {
      "allOf": [
        { "$ref": "#/definitions/appService" },
        {
          "properties": {
            "authDisabled": { "type": "boolean" },
            "oidc": {
              "type": "object",
              "properties": {
                "existingSecret": { "type": "string" },
                "issuer":         { "type": "string" },
                "audience":       { "type": "string" },
                "clientId":       { "type": "string" },
                "redirectUri":    { "type": "string" }
              }
            }
          }
        }
      ]
    },

    "analyticsApi":       { "$ref": "#/definitions/appService" },
    "identity":           { "$ref": "#/definitions/appService" },
    "frontend":           { "$ref": "#/definitions/appService" }
  },

  "definitions": {
    "infraDep": {
      "type": "object",
      "properties": {
        "deploy":   { "type": "boolean" },
        "host":     { "type": "string" },
        "port":     { "type": "integer", "minimum": 1, "maximum": 65535 },
        "database": { "type": "string" },
        "username": { "type": "string" },
        "passwordSecret": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "key":  { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "appService": {
      "type": "object",
      "properties": {
        "replicaCount":  { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag":        { "type": "string" },
            "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "resources": { "type": "object" }
      }
    }
  }
}
