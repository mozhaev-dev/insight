apiVersion: v1
kind: Secret
metadata:
  name: insight-claude-enterprise-main
  namespace: insight
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: claude-enterprise
    insight.cyberfabric.com/source-id: claude-enterprise-main
type: Opaque
stringData:
  # Required — created at claude.ai/analytics/api-keys by a Primary Owner with read:analytics scope
  analytics_api_key: "CHANGE_ME"

  # Optional — earliest date to collect from. YYYY-MM-DD.
  # Defaults to 14 days ago. Clamped to 2026-01-01 (API rejects pre-2026 dates).
  # start_date: "2026-01-01"

  # Optional — base URL override for local development against a stub service.
  # Defaults to https://api.anthropic.com (production).
  # base_url: "http://claude-enterprise-stub.dev.svc.cluster.local:8080"
