apiVersion: v1
kind: Secret
metadata:
  name: insight-github-main
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: github
    insight.cyberfabric.com/source-id: github-main
type: Opaque
stringData:
  github_token: "ghp_CHANGE_ME"
  github_organizations: '["myorg"]'
  github_start_date: "2024-01-01T00:00:00Z"
