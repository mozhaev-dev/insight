apiVersion: v1
kind: Secret
metadata:
  name: insight-github-copilot-main
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: github-copilot
    insight.cyberfabric.com/source-id: github-copilot-main
type: Opaque
stringData:
  # Classic PAT with `manage_billing:copilot` AND `read:org` scopes.
  # Created by an Organization Owner at:
  #   github.com → Settings → Developer settings → Personal access tokens → Tokens (classic)
  # Fine-grained PATs do NOT support these scopes.
  github_token: "ghp_CHANGE_ME"

  # GitHub organization slug (e.g. "my-company"). Must have active Copilot for
  # Business or Enterprise subscription.
  github_org: "CHANGE_ME"

  # Optional: earliest date for metrics backfill (YYYY-MM-DD).
  # Defaults to 90 days ago. Note: Copilot reports API only has data from
  # 2025-10-10 onwards; earlier dates return HTTP 204.
  # github_start_date: "2026-01-01"

# `insight_source_id` is NOT a stringData field — it is injected by the platform
# from the `insight.cyberfabric.com/source-id` annotation above. The annotation
# value MUST be unique per Copilot connection within a tenant — `check_connection()`
# rejects empty source_id to prevent silent dedup collisions in copilot_org_metrics.
